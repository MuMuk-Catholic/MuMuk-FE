<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.category.health.CategoryLowSugarFragment">

    <ImageView
        android:id="@+id/category_back_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="19dp"
        android:src="@drawable/ic_category_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/category_under_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="알림"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:textColor="@color/black"
        android:fontFamily="@font/pretendard_bold"
        app:layout_constraintStart_toEndOf="@id/category_back_btn"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/category_title_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/category_under_title_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/alarm_list_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="알림 리스트"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:fontFamily="@font/pretendard_medium"
        android:layout_marginTop="22dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/category_title_divider"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_alarm_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="6dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/alarm_list_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/text_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="새로운 소식이 없습니다."
        android:textColor="#A2A2A2"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="56dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/alarm_list_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>