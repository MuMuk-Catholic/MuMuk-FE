<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 로그인 UI 전체 -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/login_intro_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">


        <TextView
            android:id="@+id/iv_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="50dp"
            android:text="MUMUK"
            android:textSize="55sp"
            android:fontFamily="@font/pretendard_bold"
            android:textColor="@color/green_300"
            app:layout_constraintBottom_toTopOf="@id/et_id"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_id"
            android:layout_width="372dp"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/logintext_border"
            android:hint="아이디를 입력하세요"
            android:inputType="text"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#A2A2A2"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/et_password"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <EditText
            android:id="@+id/et_password"
            android:layout_width="372dp"
            android:layout_height="52dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/logintext_border"
            android:hint="비밀번호를 입력하세요"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#A2A2A2"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/btn_login"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/iv_toggle_pw"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="14dp"
            android:contentDescription="비밀번호 보기 토글"
            android:src="@drawable/ic_eyeclosed"
            app:layout_constraintTop_toTopOf="@id/et_password"
            app:layout_constraintBottom_toBottomOf="@id/et_password"
            app:layout_constraintEnd_toEndOf="@id/et_password" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_login"
            android:layout_width="372dp"
            android:layout_height="60dp"
            android:background="@drawable/btn_login_round"
            android:text="로그인"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_find_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="110dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="4dp"
            android:text="아이디  /  비밀번호 찾기  /  "
            android:textColor="#A2A2A2"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btn_signup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_login" />

        <TextView
            android:id="@+id/btn_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="20dp"
            android:text="회원가입"
            android:textColor="#A2A2A2"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tv_find_account"
            app:layout_constraintTop_toBottomOf="@id/btn_login" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_login_naver"
            android:layout_width="372dp"
            android:layout_height="60dp"
            android:layout_marginTop="60dp"
            android:background="@drawable/btn_social_login"
            android:stateListAnimator="@null"
            android:backgroundTint="#03C75A"
            android:text="네이버 로그인"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_find_account" />

        <ImageView
            android:id="@+id/ic_naver_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="17dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="네이버 로고"
            android:elevation="8dp"
            android:src="@drawable/ic_naver_logo"
            app:layout_constraintStart_toStartOf="@id/btn_login_naver"
            app:layout_constraintTop_toTopOf="@id/btn_login_naver" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_login_kakao"
            android:layout_width="372dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_social_login"
            android:backgroundTint="#FEE500"
            android:stateListAnimator="@null"
            android:text="카카오 로그인"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_login_naver" />

        <ImageView
            android:id="@+id/ic_kakao_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:contentDescription="카카오톡 로고"
            android:elevation="8dp"
            android:src="@drawable/ic_kakao_logo"
            app:layout_constraintStart_toStartOf="@id/btn_login_kakao"
            app:layout_constraintTop_toTopOf="@id/btn_login_kakao" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/login_intro_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>


</FrameLayout>


